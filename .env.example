APP_ENV=production
APP_NAME=CORE Wine Club
API_V1_PREFIX=/api/v1

# Render / Supabase Postgres. Keep real values only in provider dashboards or local private env files.
DATABASE_URL=
JWT_SECRET=
DEV_AUTH_ENABLED=false

# Backend CORS. Use the real Vercel frontend origin in deployment env, not in git.
CORS_ORIGINS=
BACKEND_CORS_ORIGINS=
ALLOWED_ORIGINS=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEB_APP_URL=
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_NAME=Дочь винодела
TELEGRAM_BOT_POLLING_ALLOWED=false
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

DEV_TELEGRAM_ID=100001
DEV_TELEGRAM_USERNAME=core_dev_user
DEV_TELEGRAM_FIRST_NAME=CORE
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MOBILE_PREVIEW_ENABLED=false

# Vercel frontend env.
VITE_API_BASE_URL=
VITE_PROJECT_SLUG=doch-vinodela
VITE_DEV_TELEGRAM_MOCK=false
